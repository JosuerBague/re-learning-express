<html>
    <head>
        <title><%= title %></title>
        <link rel="stylesheet" href="/styles.css"/>
    </head>
    <body>
        <ul>
            <% messages.forEach((message) => { %>
                <%- include('messages/message', { user: message.user, date: message.added, message: message.text }); %>
            <% }); %>
        </ul>
    </body>
</html>
